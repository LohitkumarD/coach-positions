DJANGO_SECRET_KEY=change-me
DJANGO_DEBUG=False
# Set True only when you intend to expose self-service signup (rate-limited, honeypot, contributor-only).
ALLOW_OPEN_REGISTRATION=False
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,.onrender.com
# Use cloud DB (Neon) in shared/prod environments.
# Example:
# DATABASE_URL=postgresql://user:password@ep-xxxx.ap-southeast-1.aws.neon.tech/dbname?sslmode=require
DATABASE_URL=postgresql://user:password@host:5432/dbname
# Optional: Neon URLs may include channel_binding=require; some Windows dev setups need:
# PG_CHANNEL_BINDING=prefer
CSRF_TRUSTED_ORIGINS=https://*.onrender.com
FCM_CREDENTIALS_JSON=
GEMINI_API_KEY=
# Use a model your key supports (see Google AI Studio). New keys often cannot use gemini-2.0-flash.
GEMINI_MODEL=gemini-1.5-flash-latest
ALERT_RETRY_MAX_ATTEMPTS=5
ALERT_RETRY_BACKOFF_SECONDS=10
CRITICAL_ACK_TIMEOUT_SECONDS=180
SSE_HEARTBEAT_SECONDS=30
# Optional: coach image scan uses Google AI (get a key at https://aistudio.google.com/apikey)
